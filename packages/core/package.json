    "test": "vitest run",
    "start": "node dist/cli.js"
  },
  "bin": {
    "roickbot-server": "dist/cli.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "ws": "^8.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
