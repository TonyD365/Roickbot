{
  "name": "@roickbot/core",
  "version": "0.1.0",
  "description": "Core MCP server + Studio bridge + security for Roickbot.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
