{
  "name": "@claude-roblox/desktop",
  "version": "0.1.0",
  "description": "Desktop app (Electron) for Claude-for-Roblox-Studio.",
  "license": "MIT",
  "author": "TonyD365",
  "repository": {
    "type": "git",
    "url": "https://github.com/TonyD365/Claude-for-Roblox-Studio.git"
  },
  "main": "dist/main/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-renderer.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder --config electron-builder.yml --publish never"
  },
  "dependencies": {
    "@claude-roblox/core": "0.1.0"
  },
  "devDependencies": {
    "electron": "31.7.7",
    "electron-builder": "^24.13.3",
    "typescript": "^5.5.0"
  }
}
